{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candidates",
  "description": "Array of candidate entries for the Dirtroad Organizing map",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "level", "office", "cycle", "lat", "lng"],
    "properties": {
      "name": {
        "type": "string",
        "description": "Candidate's full name"
      },
      "level": {
        "type": "string",
        "enum": ["state", "county", "local"],
        "description": "Office level — drives marker color (state, county, or local)"
      },
      "office": {
        "type": "string",
        "description": "Office title for display (e.g., State Representative, County Commissioner)"
      },
      "district": {
        "type": "string",
        "description": "District identifier displayed as-is (e.g., District 42, Deschutes County)"
      },
      "town": {
        "type": "string",
        "description": "Town or city name"
      },
      "state": {
        "type": "string",
        "description": "Full state name (e.g., Maine, Tennessee)"
      },
      "photo": {
        "type": "string",
        "description": "URL to a thumbnail photo (empty string if not available)"
      },
      "website": {
        "type": "string",
        "description": "URL to campaign website"
      },
      "cycle": {
        "type": "string",
        "description": "Election cycle/year (e.g., 2024, 2026)"
      },
      "lat": {
        "type": "number",
        "description": "Latitude coordinate",
        "minimum": -90,
        "maximum": 90
      },
      "lng": {
        "type": "number",
        "description": "Longitude coordinate",
        "minimum": -180,
        "maximum": 180
      }
    },
    "additionalProperties": false
  }
}
